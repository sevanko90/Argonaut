<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:json="clr-namespace:Argonaut.Features.Json"
             xmlns:search="clr-namespace:Argonaut.Features.Search"
             x:Class="Argonaut.Features.Json.JsonView"
             x:DataType="json:JsonViewModel">
    <UserControl.Resources>
        <json:DepthToMarginConverter x:Key="DepthToMargin" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.pathiconbutton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.pathiconbutton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppHoverBackgroundBrush}" />
        </Style>
        <Style Selector="Button.pathiconbutton:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>

        <Style Selector="Button.pathlink">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="Button.pathlink:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentHoverBrush}" />
        </Style>

        <Style Selector="Button.hintlink">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource AppMonoFontFamily}" />
        </Style>
        <Style Selector="Button.hintlink:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        </Style>
    </UserControl.Styles>

    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{DynamicResource AppWindowBackgroundBrush}"
            ClipToBounds="True">
        <Grid RowDefinitions="*,Auto">
            <ListBox Grid.Row="0"
                     x:Name="RowsListBox"
                     ItemsSource="{Binding Rows}"
                     SelectionMode="Single"
                     Padding="8,6"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="22" />
                        <Setter Property="Height" Value="22" />
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="json:JsonRow">
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Depth, Converter={StaticResource DepthToMargin}}"
                                    PointerPressed="OnRowPointerPressed">
                            <Button Content="{Binding IsExpanded, Converter={x:Static json:ExpandGlyphConverter.Instance}}"
                                    Click="OnToggleExpandClick"
                                    IsVisible="{Binding HasChildren}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Width="16"
                                    HorizontalContentAlignment="Center"
                                    FontFamily="{StaticResource AppMonoFontFamily}" />
                            <TextBlock IsVisible="{Binding !HasChildren}"
                                       Width="16" />
                            <TextBlock search:SearchHighlight.Text="{Binding Name}"
                                       search:SearchHighlight.Suffix=": "
                                       search:SearchHighlight.Term="{Binding $parent[json:JsonView].((json:JsonViewModel)DataContext).HighlightTerm}"
                                       IsVisible="{Binding Name, Converter={x:Static json:IsNotNullConverter.Instance}}"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       FontFamily="{StaticResource AppMonoFontFamily}" />
                            <TextBlock search:SearchHighlight.Text="{Binding Value}"
                                       search:SearchHighlight.Term="{Binding $parent[json:JsonView].((json:JsonViewModel)DataContext).HighlightTerm}"
                                       TextWrapping="NoWrap"
                                       FontFamily="{StaticResource AppMonoFontFamily}" />
                            <Button Classes="hintlink"
                                    Content="{Binding Hint}"
                                    IsVisible="{Binding Hint, Converter={x:Static json:IsNotNullConverter.Instance}}"
                                    Click="OnHintClick"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Decoded date (local time) — click to change scheme" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Background="{DynamicResource AppPanelBackgroundBrush}"
                    Padding="10,4">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="No selection"
                               FontSize="11"
                               VerticalAlignment="Center"
                               IsVisible="{Binding SelectedPath, Converter={x:Static json:IsNullConverter.Instance}}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontFamily="{StaticResource AppMonoFontFamily}" />
                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding SelectedPathSegments}"
                                  IsVisible="{Binding SelectedPath, Converter={x:Static json:IsNotNullConverter.Instance}}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="json:JsonPathSegment">
                                <Button Content="{Binding Label}"
                                        Click="OnPathSegmentClick"
                                        Classes="pathlink"
                                        FontSize="11"
                                        FontFamily="{StaticResource AppMonoFontFamily}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="CopyValueButton"
                                Classes="pathiconbutton"
                                Click="OnCopyValueClick"
                                IsEnabled="{Binding SelectedPath, Converter={x:Static json:IsNotNullConverter.Instance}}"
                                ToolTip.Tip="Copy value"
                                Margin="8,0,0,0">
                            <Viewbox Width="12" Height="12">
                                <Path Fill="{DynamicResource AppMutedTextBrush}"
                                      Data="M16 1H4a2 2 0 0 0-2 2v14h2V3h12V1zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H8V7h11v14z" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="CopyPathButton"
                                Classes="pathiconbutton"
                                Click="OnCopyPathClick"
                                IsEnabled="{Binding SelectedPath, Converter={x:Static json:IsNotNullConverter.Instance}}"
                                ToolTip.Tip="Copy JSONPath"
                                Margin="8,0,0,0">
                            <Viewbox Width="12" Height="12">
                                <Path Fill="{DynamicResource AppMutedTextBrush}"
                                      Data="M18 2H9a2 2 0 0 0-2 2v2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-2h2a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zM14 20H5V8h9v12zm4-4h-2V8a2 2 0 0 0-2-2H9V4h9v12z" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
