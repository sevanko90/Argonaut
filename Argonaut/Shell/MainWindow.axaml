<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Argonaut.Shell.MainWindow"
        x:DataType="shell:MainWindowViewModel"
        xmlns:shell="clr-namespace:Argonaut.Shell"
        xmlns:search="clr-namespace:Argonaut.Features.Search"
        xmlns:json="clr-namespace:Argonaut.Features.Json"
        xmlns:ndjson="clr-namespace:Argonaut.Features.NdJson"
        xmlns:csv="clr-namespace:Argonaut.Features.Csv"
        Title="{Binding Title}"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Width="1000" Height="700">

    <Window.DataTemplates>
        <DataTemplate DataType="json:JsonViewModel">
            <json:JsonView />
        </DataTemplate>
        <DataTemplate DataType="ndjson:NdJsonViewModel">
            <ndjson:NdJsonView />
        </DataTemplate>
        <DataTemplate DataType="csv:CsvViewModel">
            <csv:CsvView />
        </DataTemplate>
        <DataTemplate DataType="json:JsonToolbarViewModel">
            <json:JsonToolbarView />
        </DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                x:Name="ToolbarBar"
                IsVisible="{Binding IsFileOpen}"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                <search:FindBar Grid.Column="0"
                                x:Name="FindBarControl"
                                VerticalAlignment="Center" />
                <ContentControl Grid.Column="1"
                                x:Name="DocumentToolbarArea"
                                Content="{Binding CurrentDocument.Toolbar, FallbackValue={x:Null}}"
                                VerticalAlignment="Center" />
                <Border Grid.Column="3"
                        Width="1"
                        Margin="12,2,12,2"
                        Background="{DynamicResource AppBorderBrush}" />
                <Button Grid.Column="4"
                        x:Name="CloseFileButton"
                        Click="OnCloseFile"
                        Classes="iconbutton"
                        ToolTip.Tip="Close file">
                    <Viewbox Width="14" Height="14">
                        <Path Fill="{DynamicResource AppMutedTextBrush}"
                              Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                    </Viewbox>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1"
                        x:Name="ContentArea"
                        Content="{Binding CurrentDocument}" />

        <shell:EmptyStateView Grid.Row="1"
                              x:Name="EmptyState"
                              IsVisible="{Binding !IsFileOpen}" />

        <Border Grid.Row="1"
                x:Name="ToastBorder"
                IsVisible="False"
                IsHitTestVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,16"
                Padding="12,6"
                CornerRadius="6"
                Background="{DynamicResource AppAccentBrush}">
            <TextBlock x:Name="ToastText"
                       Foreground="White"
                       FontSize="12" />
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           x:Name="StatusText"
                           Text="{Binding StatusText}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="FontToggleButton"
                            Click="OnToggleContentFont"
                            Classes="iconbutton compact"
                            Margin="8,0,0,0">
                        <Viewbox Width="14" Height="14">
                            <!-- Material "text_fields" -->
                            <Path Fill="{DynamicResource AppMutedTextBrush}"
                                  Data="M2.5 4v3h5v12h3V7h5V4h-13zm19 5h-9v3h3v7h3v-7h3V9z" />
                        </Viewbox>
                    </Button>
                    <Button x:Name="ThemeToggleButton"
                            Click="OnToggleTheme"
                            Classes="iconbutton compact"
                            Margin="8,0,0,0">
                        <Viewbox Width="14" Height="14">
                            <Path x:Name="ThemeToggleIcon"
                                  Fill="{DynamicResource AppMutedTextBrush}" />
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
