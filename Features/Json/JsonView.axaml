<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:json="clr-namespace:JsonViewerCore.Features.Json"
             x:Class="JsonViewerCore.Features.Json.JsonView"
             x:DataType="json:JsonViewModel">
    <ListBox ItemsSource="{Binding Nodes}">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>

        <ListBox.ItemTemplate>
            <DataTemplate>
                <TextBlock Text="{Binding Text}"
                           Margin="{Binding Depth, Converter={StaticResource DepthToMargin}}" />
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>