<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:json="clr-namespace:JsonViewerCore.Features.NdJson"
             x:Class="JsonViewerCore.Features.NdJson.NdJsonView"
             x:DataType="json:NdJsonViewModel">
    <Grid ColumnDefinitions="*,5,*">
        <ListBox x:Name="JsonLinesListBox"
                 Grid.Column="0"
                 ItemsSource="{Binding Lines}"
                 SelectionMode="Single">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="20" />
                    <Setter Property="Height" Value="20" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="json:NdJsonVisibleLine">
                    <Grid ColumnDefinitions="72,*">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding LineNumber}"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,12,0"
                                   Foreground="#9A9A9A"
                                   FontFamily="Consolas, Monaco, 'Courier New', monospace" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Text}"
                                   TextWrapping="NoWrap"
                                   FontFamily="Consolas, Monaco, 'Courier New', monospace" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <GridSplitter Grid.Column="1"
                      Width="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#5A5A5A" />

        <Border Grid.Column="2" Padding="8">
            <TextBox Text="{Binding SelectedLineText, Mode=OneWay}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas, Monaco, 'Courier New', monospace"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0" />
        </Border>
    </Grid>
</UserControl>
