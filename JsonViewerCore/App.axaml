<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="JsonViewerCore.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="AppMutedTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="AppLinkBrush" Color="DodgerBlue" />
        <FontFamily x:Key="AppMonoFontFamily">Consolas, Monaco, 'Courier New', monospace</FontFamily>
    </Application.Resources>
</Application>