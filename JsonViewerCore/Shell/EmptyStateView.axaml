<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="JsonViewerCore.Shell.EmptyStateView">

    <UserControl.Styles>
        <Style Selector="Button.linklike">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.linklike:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentHoverBrush}" />
            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="Button.clearlist">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.clearlist:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource AppDangerHoverBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Orientation="Vertical" Spacing="20" HorizontalAlignment="Center">

            <Viewbox Width="120" Height="120" Stretch="Uniform" HorizontalAlignment="Center">
                <Path Fill="{DynamicResource AppSubtleIconBrush}"
                      Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z" />
            </Viewbox>

            <TextBlock Text="Drag file here or choose from file picker to load"
                       FontSize="16"
                       Foreground="{DynamicResource AppMutedTextBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Width="320" />

            <Button Content="Choose file…"
                    Click="OnChooseFile"
                    HorizontalAlignment="Center"
                    Padding="20,8" />

            <StackPanel Orientation="Vertical" Spacing="4" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Grid ColumnDefinitions="Auto,Auto" HorizontalAlignment="Center">
                    <TextBlock Grid.Column="0" Text="Recent files" FontWeight="SemiBold" Opacity="0.7"
                               VerticalAlignment="Center" />
                    <Button x:Name="ClearRecentFilesButton" Grid.Column="1" Content="✕" FontSize="11"
                            Classes="clearlist" Click="OnClearRecentFiles" Margin="6,0,0,0"
                            VerticalAlignment="Center" ToolTip.Tip="Clear recent files" />
                </Grid>
                <StackPanel x:Name="RecentFilesPanel" Orientation="Vertical" Spacing="4" HorizontalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
