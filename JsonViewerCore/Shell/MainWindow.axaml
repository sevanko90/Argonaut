<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JsonViewerCore.Shell.MainWindow"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Width="1000" Height="700">

    <Grid>
        <Grid.Styles>
            <Style Selector="Button.iconbutton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style Selector="Button.iconbutton:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource AppHoverBackgroundBrush}" />
            </Style>
        </Grid.Styles>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                x:Name="FileHeaderBar"
                IsVisible="False"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           x:Name="FileNameText"
                           FontWeight="SemiBold"
                           FontSize="14"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        x:Name="CloseFileButton"
                        Click="OnCloseFile"
                        Classes="iconbutton"
                        ToolTip.Tip="Close file">
                    <Viewbox Width="14" Height="14">
                        <Path Fill="{DynamicResource AppMutedTextBrush}"
                              Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                    </Viewbox>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1" x:Name="ContentArea" />

        <Border Grid.Row="2"
                Background="{DynamicResource AppPanelBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           x:Name="StatusText"
                           Text="No file loaded"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <Button Grid.Column="1"
                        x:Name="ThemeToggleButton"
                        Click="OnToggleTheme"
                        Classes="iconbutton"
                        Padding="4"
                        Margin="8,0,0,0">
                    <Viewbox Width="14" Height="14">
                        <Path x:Name="ThemeToggleIcon"
                              Fill="{DynamicResource AppMutedTextBrush}" />
                    </Viewbox>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
